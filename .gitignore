# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
build/
dist/

# ============================================================================
# 가상 환경 (uv.lock은 재현성을 위해 커밋)
# ============================================================================
.venv/
venv/
.python-version

# ============================================================================
# 테스트 / 린터 / 타입 체크 캐시
# ============================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.hypothesis/

# ============================================================================
# 데이터 (원본·전처리 결과는 용량이 크므로 제외)
# ============================================================================
data/raw/
data/processed/
data/interim/
data/cache/
*.csv
*.tsv
*.parquet
*.arrow
!tests/fixtures/*.csv

# ============================================================================
# 모델 및 체크포인트 (대용량 바이너리)
# ============================================================================
artifacts/checkpoints/
artifacts/models/
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
*.onnx
*.pkl
*.joblib

# HuggingFace 모델 캐시
.cache/

# ============================================================================
# 시각화 / 자동 생성 리포트
# ============================================================================
artifacts/*.png
artifacts/*.jpg
artifacts/*.svg
artifacts/*.pdf
!artifacts/.gitkeep

# ============================================================================
# 로그 및 ML 실험 추적
# ============================================================================
logs/
*.log
runs/
wandb/
mlruns/

# ============================================================================
# 하네스 런타임 상태 (세션마다 자동 생성)
# ============================================================================
.harness/cost-ledger.json
.harness/escalation-log.md
.harness/sprints/**/evaluation-report.md
.harness/sprints/**/evaluation-report-r*.md
# 계약서·템플릿은 커밋 대상
!.harness/sprint-contract.yaml
!.harness/claude-progress.txt
!.harness/sprints/**/*.template

# ============================================================================
# 노트북 체크포인트
# ============================================================================
.ipynb_checkpoints/
notebooks/**/*.html

# ============================================================================
# 환경 변수 / 시크릿
# ============================================================================
.env
.env.*
*.pem
*.key
secrets/

# ============================================================================
# IDE / OS
# ============================================================================
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# ============================================================================
# 임시 파일
# ============================================================================
*.tmp
*.bak
scratch/
tmp/
